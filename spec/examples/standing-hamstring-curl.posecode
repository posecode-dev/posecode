posecode exercise "Standing hamstring curl"
  rig humanoid
  pose start = standing

  step "Curl" 1.4s ease-out:
    knee_right: flex 95
    cue "Bend the right knee, drawing the heel toward the glute"

  step "Lower" 1.6s ease-in:
    knee_right: flex 0
    cue "Lower the foot back to the floor"

  repeat 10
