movit exercise "Triceps dips"
  rig humanoid
  prop chair
  pose start = standing

  step "Lower" 1.2s ease-in-out:
    shoulders: extend 30
    elbows: flex 90
    hips: flex 80
    knees: flex 80
    cue "Hands on the edge behind you, bend the elbows to lower the hips"

  step "Press" 1s ease-out:
    elbows: flex 10
    cue "Press through the palms to straighten the arms"

  repeat 8
