posecode stretch "Hip flexion (ROM demo)"
  rig humanoid
  pose start = standing

  step "Lift" 2.5s flow:
    hip_right: flex 90
    pin: foot_left floor
    cue "Raise the straight right leg forward: sagittal-plane hip flexion"

  step "Lower" 2.5s settle:
    hip_right: flex 0
    ground-lock: feet
    cue "Lower the leg back under the hip"

  repeat 4
