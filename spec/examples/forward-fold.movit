movit stretch "Standing forward fold"
  rig humanoid
  pose start = standing

  step "Fold" 3s ease-in-out:
    hips: hinge 90
    spine: flex 30
    neck: flex 15
    shoulders: flex 120
    knees: flex 8
    ground-lock: feet
    cue "Hinge at the hips and let the arms hang heavy"

  step "Rise" 2.5s ease-in-out:
    hips: hinge 0
    spine: flex 0
    neck: flex 0
    shoulders: flex 0
    knees: flex 0
    ground-lock: feet
    cue "Press the feet down and hinge back up to standing"

  repeat 2
