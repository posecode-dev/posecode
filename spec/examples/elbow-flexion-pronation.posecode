posecode stretch "Elbow flexion & forearm rotation (ROM demo)"
  rig humanoid
  pose start = standing

  step "Flex with palms up" 2.5s flow:
    elbows: flex 140
    forearms: pronate 0
    cue "Bend the elbows and reduce pronation until the palms face up"

  step "Extend & pronate" 2.5s settle:
    elbows: flex 10
    elbows: pronate 80
    cue "Straighten and turn the palms inward toward the thighs with pronation"

  repeat 4
