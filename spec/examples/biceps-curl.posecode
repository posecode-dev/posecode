posecode exercise "Biceps curl"
  rig humanoid
  pose start = standing

  step "Curl" 1.1s settle:
    elbows: flex 135
    forearms: pronate 0
    cue "Curl up, keep the elbows tucked at your sides"

  step "Lower" 1.4s settle:
    elbows: flex 15
    forearms: pronate 0
    cue "Lower under control: don't swing"

  repeat 10
