posecode posture "Standing bow"
  rig humanoid
  pose start = standing

  step "Bow" 2s ease-in-out:
    pelvis: hinge 35
    neck: flex 15
    shoulders: extend 5
    ground-lock: feet
    cue "Hinge forward from the hips into a respectful bow, back flat"

  step "Rise" 2s ease-out:
    pelvis: hinge 0
    neck: flex 0
    shoulders: extend 0
    ground-lock: feet
    cue "Return smoothly to standing"

  repeat 3
