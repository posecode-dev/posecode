posecode posture "Plank hold"
  rig humanoid
  pose start = plank

  step "Brace" 0.5s flow:
    shoulders: flex 90
    elbows: flex 90
    elbows: pronate 80
    ground-lock: forearms, feet
    cue "Plant the forearms with the elbows directly under the shoulders"

  step "Hold" 3s linear:
    shoulders: flex 90
    elbows: flex 90
    elbows: pronate 80
    ground-lock: forearms, feet
    cue "Brace the core: one straight line from head to heels"

  repeat 3
