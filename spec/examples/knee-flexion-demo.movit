movit stretch "Knee flexion (ROM demo)"
  rig humanoid
  pose start = standing

  step "Flex" 2.5s ease-in-out:
    knee_right: flex 130
    cue "Bend the right knee, heel toward the glutes — the knee's single plane"

  step "Extend" 2.5s ease-in-out:
    knee_right: flex 0
    cue "Lower the shin back to standing"

  repeat 4
