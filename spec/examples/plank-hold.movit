movit posture "Plank hold"
  rig humanoid
  pose start = plank

  step "Brace" 3s ease-in-out:
    spine: hold neutral
    hips: hold neutral
    ground-lock: hands, feet
    cue "Brace the core — one straight line from head to heels"

  step "Hold" 3s linear:
    spine: hold neutral
    ground-lock: hands, feet
    cue "Keep breathing, ribs down, glutes engaged"

  repeat 3
