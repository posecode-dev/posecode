{
  "name": "movit-lsp",
  "version": "0.1.0",
  "description": "Language Server Protocol implementation for the Movit (.movit) DSL — diagnostics, completion, and hover, powered by movit-language.",
  "license": "MIT",
  "type": "module",
  "main": "./src/server.ts",
  "exports": {
    ".": "./src/server.ts",
    "./convert": "./src/convert.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "bundle": "esbuild src/server.ts --bundle --platform=node --format=cjs --outfile=dist/server.cjs",
    "start": "tsx src/server.ts"
  },
  "dependencies": {
    "movit-language": "0.1.0",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "esbuild": "^0.24.2",
    "tsx": "^4.19.2"
  }
}
