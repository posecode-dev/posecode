{
  "name": "movit-mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server for Movit — let any LLM agent validate, ROM-check, and get a render link for a .movit movement, natively.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "movit-mcp": "dist/movit-mcp.mjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "start": "tsx src/stdio.ts",
    "build": "esbuild src/stdio.ts --bundle --platform=node --format=esm --external:@modelcontextprotocol/sdk --external:zod --outfile=dist/movit-mcp.mjs",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a-baran-orhan/movit.git",
    "directory": "packages/movit-mcp"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "movit",
    "kinematics",
    "3d",
    "animation",
    "fitness",
    "physiotherapy"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "esbuild": "^0.24.2",
    "movit-parser": "0.1.0",
    "movit-share": "0.1.0",
    "tsx": "^4.19.2"
  }
}
