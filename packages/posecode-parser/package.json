{
  "name": "posecode-parser",
  "version": "0.4.0",
  "description": "Parse the .posecode kinematic motion DSL into a validated, ROM-clamped intermediate representation.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "posecode-parser": "dist/cli.js"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/posecode-dev/posecode.git",
    "directory": "packages/posecode-parser"
  },
  "keywords": [
    "posecode",
    "kinematics",
    "dsl",
    "parser",
    "llm",
    "text-to-motion",
    "biomechanics"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
