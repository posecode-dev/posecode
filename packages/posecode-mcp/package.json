{
  "name": "posecode-mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server for Posecode \u2014 let any LLM agent validate, ROM-check, and get a render link for a .posecode movement, natively.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "posecode-mcp": "dist/posecode-mcp.mjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "start": "tsx src/stdio.ts",
    "build": "tsc -p tsconfig.json && esbuild src/stdio.ts --bundle --platform=node --format=esm --external:@modelcontextprotocol/sdk --external:zod --outfile=dist/posecode-mcp.mjs",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/posecode-dev/posecode.git",
    "directory": "packages/posecode-mcp"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "posecode",
    "kinematics",
    "3d",
    "animation",
    "fitness",
    "physiotherapy"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "posecode-parser": "0.1.0",
    "posecode-share": "0.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "esbuild": "^0.24.2",
    "tsx": "^4.19.2"
  }
}
